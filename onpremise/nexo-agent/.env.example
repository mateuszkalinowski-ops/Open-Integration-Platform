# InsERT Nexo On-Premise Agent — Environment Variables
# Copy this file to .env and fill in your values

# Agent identification
NEXO_AGENT_ID=nexo-agent-001

# SQL Server connection (where InsERT Nexo database is hosted)
NEXO_SQL_SERVER=(local)\INSERTNEXO
NEXO_SQL_DATABASE=Nexo_demo
NEXO_SQL_AUTH_WINDOWS=true
# Only needed if NEXO_SQL_AUTH_WINDOWS=false:
# NEXO_SQL_USERNAME=sa
# NEXO_SQL_PASSWORD=your_password

# Nexo operator credentials
NEXO_OPERATOR_LOGIN=Admin
NEXO_OPERATOR_PASSWORD=your_nexo_password

# Nexo product (Subiekt, Rachmistrz, Rewizor, Gratyfikant)
NEXO_PRODUCT=Subiekt

# Path to InsERT Nexo SDK Bin directory
NEXO_SDK_BIN_PATH=C:\nexoSDK\Bin

# Default context
NEXO_AGENT_DEFAULT_WAREHOUSE=MAG
NEXO_AGENT_DEFAULT_BRANCH=CENTRALA

# Pinquark Cloud Platform
CLOUD_PLATFORM_URL=https://integrations.pinquark.com
CLOUD_API_KEY=your_cloud_api_key

# Sync settings
NEXO_AGENT_SYNC_INTERVAL_SECONDS=300
NEXO_AGENT_HEARTBEAT_INTERVAL_SECONDS=60

# Logging
NEXO_AGENT_LOG_LEVEL=INFO

# Kafka (optional)
KAFKA_ENABLED=false
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
