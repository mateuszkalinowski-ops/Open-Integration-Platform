{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "integrations-lib": {
      "projectType": "library",
      "root": "projects/integrations-lib",
      "sourceRoot": "projects/integrations-lib/src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/integrations-lib/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/integrations-lib/tsconfig.lib.prod.json"
            }
          }
        }
      }
    },
    "dashboard-app": {
      "projectType": "application",
      "root": "projects/dashboard-app",
      "sourceRoot": "projects/dashboard-app/src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/dashboard-app",
            "index": "projects/dashboard-app/src/index.html",
            "browser": "projects/dashboard-app/src/main.ts",
            "tsConfig": "projects/dashboard-app/tsconfig.app.json",
            "polyfills": ["zone.js"],
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/dashboard-app/src/assets",
                "output": "assets"
              }
            ],
            "styles": [
              "@angular/material/prebuilt-themes/azure-blue.css",
              "node_modules/swagger-ui-dist/swagger-ui.css",
              "projects/dashboard-app/src/styles.css"
            ],
            "scripts": [
              "node_modules/swagger-ui-dist/swagger-ui-bundle.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "3mb", "maximumError": "4mb" }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "buildTarget": "dashboard-app:build:production" },
            "development": { "buildTarget": "dashboard-app:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
