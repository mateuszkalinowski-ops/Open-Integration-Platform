APP_ENV=development
APP_PORT=8080
LOG_LEVEL=INFO

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://DB_USER:DB_PASSWORD@localhost:5432/pinquark_platform
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5.0
REDIS_CACHE_TTL=300

# Rate limiting (per-tenant)
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60

# Encryption — AES-256-GCM (generate with: python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())")
ENCRYPTION_KEY=REPLACE_WITH_GENERATED_KEY

# JWT
JWT_SECRET_KEY=REPLACE_WITH_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Connector discovery
CONNECTOR_DISCOVERY_PATH=../integrators

# CORS (comma-separated origins, leave empty to disable)
CORS_ALLOWED_ORIGINS=

# Admin secret — REQUIRED to create tenants and API keys (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
ADMIN_SECRET=REPLACE_WITH_GENERATED_SECRET

# Internal secret — REQUIRED for /internal/* endpoints (connector-to-platform communication)
INTERNAL_SECRET=REPLACE_WITH_GENERATED_SECRET

# Dashboard admin secret — pass to dashboard container as PINQUARK_ADMIN_SECRET
# Must match ADMIN_SECRET above; enables verification reports and scheduler management in the UI
PINQUARK_ADMIN_SECRET=REPLACE_WITH_SAME_ADMIN_SECRET

# Demo mode — enables self-service tenant registration (disable in production)
DEMO_MODE=false

# Kafka — SASL_SSL is the default and required for production
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9093
KAFKA_CONSUMER_GROUP=platform-events
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=REPLACE_WITH_KAFKA_USERNAME
KAFKA_SASL_PASSWORD=REPLACE_WITH_KAFKA_PASSWORD
KAFKA_SSL_CAFILE=/app/certs/ca.pem

# Verification agent URL (used by gateway proxy endpoints)
VERIFICATION_AGENT_URL=http://verification-agent:8000
