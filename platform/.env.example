APP_ENV=development
APP_PORT=8080
LOG_LEVEL=INFO

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://pinquark:pinquark@localhost:5432/pinquark_platform
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5.0
REDIS_CACHE_TTL=300

# Rate limiting (per-tenant)
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60

# Encryption — AES-256-GCM (generate with: python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())")
ENCRYPTION_KEY=REPLACE_WITH_GENERATED_KEY

# JWT
JWT_SECRET_KEY=REPLACE_WITH_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Connector discovery
CONNECTOR_DISCOVERY_PATH=../integrators
