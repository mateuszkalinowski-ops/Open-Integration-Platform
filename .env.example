# pinquark Integration Platform - Environment Variables

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=admin
KAFKA_SASL_PASSWORD=changeme
KAFKA_SSL_TRUSTSTORE_LOCATION=/kafka/kafka.keystore
KAFKA_SSL_TRUSTSTORE_PASSWORD=changeme

# Database
DATABASE_URL=postgresql+asyncpg://pinquark:changeme@db:5432/integrations
DATABASE_ENCRYPTION_KEY=changeme-generate-32-byte-key-here

# Admin secret — required for tenant management and verification data in dashboard
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET=REPLACE_WITH_GENERATED_SECRET

# Monitoring
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO

# Registry
DOCKER_REGISTRY=registry.pinquark.com
