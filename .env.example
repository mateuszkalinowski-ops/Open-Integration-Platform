# Open Integration Platform — Environment Variables
# Copy this file to .env and fill in the values, or run ./setup.sh to auto-generate.

# ── Database ──
DB_PASSWORD=REPLACE_WITH_GENERATED_SECRET
# Password for the restricted pinquark_app role (enforces RLS at DB level).
# Must differ from DB_PASSWORD. The init script creates the role automatically.
DB_APP_PASSWORD=REPLACE_WITH_GENERATED_SECRET

# ── Encryption key for credential vault (AES-256-GCM) ──
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: If lost, all stored credentials become unrecoverable.
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY


# ── Internal secret for connector ↔ platform communication (/internal/* endpoints) ──
INTERNAL_SECRET=REPLACE_WITH_GENERATED_SECRET

# ── Admin secret for tenant management & admin-only endpoints ──
# Enter via Dashboard → Settings → Admin Access
ADMIN_SECRET=REPLACE_WITH_GENERATED_SECRET

# ── Connector API key (used by connectors to call back into platform) ──
PINQUARK_CONNECTOR_API_KEY=REPLACE_WITH_GENERATED_SECRET

# ── Gemini API key (used by AI agent connector) ──
# GEMINI_API_KEY=REPLACE_WITH_GEMINI_KEY

# ── Kafka (optional — only needed when Kafka is enabled) ──
# KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=admin
# KAFKA_SASL_PASSWORD=REPLACE_WITH_GENERATED_SECRET

# ── Reverse proxy — trusted IPs for X-Forwarded-For (comma-separated) ──
TRUSTED_PROXY_IPS=127.0.0.1

# ── Monitoring ──
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO
