# Symfonia ERP WebAPI Connector — Environment Variables

# Required: URL of the Symfonia WebAPI service (on-premise)
SYMFONIA_WEBAPI_URL=https://192.168.1.100:8080

# Required: Application GUID from Symfonia configurator
SYMFONIA_APPLICATION_GUID=493EB16D-7029-48AA-BB25-8BA7138D763A

# Optional: device name for session (default: pinquark-oip)
SYMFONIA_DEVICE_NAME=pinquark-oip

# Optional: connector settings
SYMFONIA_CONNECTOR_LOG_LEVEL=INFO
SYMFONIA_CONNECTOR_SESSION_TIMEOUT_MINUTES=30
SYMFONIA_CONNECTOR_SYNC_INTERVAL_SECONDS=300
