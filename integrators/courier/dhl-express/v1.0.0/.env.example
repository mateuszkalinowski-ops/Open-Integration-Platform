APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
HTTP_TIMEOUT=30
HTTP_MAX_RETRIES=3

# DHL Express MyDHL API credentials (Basic Auth)
# Obtain from https://developer.dhl.com after creating an app
DHL_EXPRESS_API_KEY=your-api-key-here
DHL_EXPRESS_API_SECRET=your-api-secret-here

# API base URLs
DHL_EXPRESS_BASE_URL=https://express.api.dhl.com/mydhlapi/test
DHL_EXPRESS_PROD_URL=https://express.api.dhl.com/mydhlapi
