# SkanujFakture Integrator v1.0.0 — Environment Variables

# Application
SF_LOG_LEVEL=INFO
SF_DEBUG=false

# Database (poller state persistence)
DATABASE_URL=sqlite+aiosqlite:///./data/skanuj_fakture_integrator.db
DATABASE_ENCRYPTION_KEY=  # base64-encoded 32-byte AES key; generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"

# Kafka (set KAFKA_ENABLED=true to publish document events to Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Polling
SF_POLLING_ENABLED=true
SF_POLLING_INTERVAL_SECONDS=300
SF_POLLING_STATUS_FILTER=zeskanowany

# Accounts are configured in config/accounts.yaml
# Or via environment variables:
# SF_ACCOUNT_0_NAME=default
# SF_ACCOUNT_0_LOGIN=user@example.com
# SF_ACCOUNT_0_PASSWORD=your-password
# SF_ACCOUNT_0_API_URL=https://skanujfakture.pl:8443/SFApi
# SF_ACCOUNT_0_COMPANY_ID=147
# SF_ACCOUNT_0_ENVIRONMENT=production

# Platform API (for event notifications)
PLATFORM_API_URL=http://platform:8080
PLATFORM_API_KEY=
PLATFORM_EVENT_NOTIFY=true
