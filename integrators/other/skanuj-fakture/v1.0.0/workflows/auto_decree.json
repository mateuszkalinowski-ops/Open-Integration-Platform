{
  "name": "SkanujFakture — Auto-dekretacja",
  "description": "Automatyczne dekretowanie dokumentów na podstawie szablonu. Wyszukuje dokumenty kontrahenta oznaczone atrybutem 'dekret-wzor', kopiuje dekretację z mapowaniem kwot. W opisie operacji dekretu-wzoru wpisz {netto}, {brutto}, {vat} lub {amount_to_pay} aby automatycznie podstawic wartosc z nowego dokumentu. Wpisy bez {…} kopiuja kwote bez zmian.",
  "on_error": "stop",
  "max_retries": 1,
  "timeout_seconds": 60,
  "variables": {},
  "nodes": [
    {
      "id": "trigger",
      "type": "trigger",
      "label": "Nowy dokument zeskanowany",
      "position": {"x": 0, "y": 300},
      "config": {
        "connector_name": "skanuj-fakture",
        "event": "document.scanned"
      }
    },
    {
      "id": "cond_has_nip",
      "type": "condition",
      "label": "Czy kontrahent ma NIP?",
      "position": {"x": 250, "y": 300},
      "config": {
        "conditions": [
          {"field": "contractor.nip", "operator": "is_not_empty"}
        ],
        "logic": "and"
      }
    },
    {
      "id": "cond_already_decreed",
      "type": "condition",
      "label": "Czy dokument ma już dekret?",
      "position": {"x": 500, "y": 300},
      "config": {
        "conditions": [
          {"field": "decrets", "operator": "is_not_empty"}
        ],
        "logic": "and"
      }
    },
    {
      "id": "cond_is_template",
      "type": "condition",
      "label": "Czy to dokument-wzór?",
      "position": {"x": 750, "y": 300},
      "config": {
        "conditions": [
          {"field": "attributes[].name", "operator": "contains", "value": "dekret-wzor"}
        ],
        "logic": "and"
      }
    },
    {
      "id": "save_doc_id",
      "type": "set_variable",
      "label": "Zapisz ID dokumentu docelowego",
      "position": {"x": 1000, "y": 300},
      "config": {
        "variable_name": "target_doc_id",
        "value": "{{ document_id }}"
      }
    },
    {
      "id": "save_account",
      "type": "set_variable",
      "label": "Zapisz konto SF",
      "position": {"x": 1200, "y": 300},
      "config": {
        "variable_name": "sf_account",
        "value": "{{ account_name }}"
      }
    },
    {
      "id": "save_company_id",
      "type": "set_variable",
      "label": "Zapisz ID firmy",
      "position": {"x": 1400, "y": 300},
      "config": {
        "variable_name": "sf_company_id",
        "value": "{{ company.id }}"
      }
    },
    {
      "id": "get_docs",
      "type": "http_request",
      "label": "Pobierz dokumenty kontrahenta",
      "position": {"x": 1600, "y": 300},
      "config": {
        "method": "GET",
        "url": "http://connector-skanuj-fakture:8000/companies/{{ vars.sf_company_id }}/documents?account_name={{ vars.sf_account }}&contractor={{ contractor.nip }}",
        "timeout_seconds": 30
      }
    },
    {
      "id": "loop_docs",
      "type": "loop",
      "label": "Przeszukaj dokumenty kontrahenta",
      "position": {"x": 1850, "y": 300},
      "config": {
        "array_field": "nodes.get_docs.body",
        "item_variable": "doc",
        "index_variable": "doc_idx",
        "max_iterations": 100
      }
    },
    {
      "id": "cond_doc_attr",
      "type": "condition",
      "label": "Czy dokument ma atrybut dekret-wzor?",
      "position": {"x": 1850, "y": 500},
      "config": {
        "conditions": [
          {"field": "vars.doc.attributes[].name", "operator": "contains", "value": "dekret-wzor"}
        ],
        "logic": "and"
      }
    },
    {
      "id": "cond_doc_decrets",
      "type": "condition",
      "label": "Czy dokument-wzór ma dekretację?",
      "position": {"x": 1850, "y": 700},
      "config": {
        "conditions": [
          {"field": "vars.doc.decrets", "operator": "is_not_empty"}
        ],
        "logic": "and"
      }
    },
    {
      "id": "save_template_dec",
      "type": "set_variable",
      "label": "Zapisz dekretację wzorcową",
      "position": {"x": 1850, "y": 900},
      "config": {
        "variable_name": "template_decrets",
        "value": "{{ vars.doc.decrets }}"
      }
    },
    {
      "id": "cond_template_found",
      "type": "condition",
      "label": "Czy znaleziono szablon dekretacji?",
      "position": {"x": 2100, "y": 300},
      "config": {
        "conditions": [
          {"field": "vars.template_decrets", "operator": "is_not_empty"}
        ],
        "logic": "and"
      }
    },
    {
      "id": "loop_decrets",
      "type": "loop",
      "label": "Przetwórz wpisy dekretacji",
      "position": {"x": 2350, "y": 300},
      "config": {
        "array_field": "vars.template_decrets",
        "item_variable": "decree_entry",
        "index_variable": "dec_idx",
        "max_iterations": 50
      }
    },
    {
      "id": "resolve_amount",
      "type": "transform",
      "label": "Ustaw kwotę z pola dokumentu",
      "position": {"x": 2350, "y": 500},
      "config": {
        "mappings": [
          {
            "from": "vars.decree_entry.description",
            "to": "resolved_amount",
            "transform": [
              {"type": "regex_extract", "pattern": "^\\{(.+)\\}$", "group": 1},
              {"type": "field_resolve", "fallback_field": "vars.decree_entry.amount"}
            ]
          }
        ]
      }
    },
    {
      "id": "rebuild_entry",
      "type": "set_variable",
      "label": "Zbuduj wpis z nową kwotą",
      "position": {"x": 2350, "y": 700},
      "config": {
        "variable_name": "decree_entry",
        "value": {
          "type": "{{ vars.decree_entry.type }}",
          "symbol": "{{ vars.decree_entry.symbol }}",
          "description": "{{ vars.decree_entry.description }}",
          "value": "{{ vars.decree_entry.value }}",
          "amount": "{{ resolved_amount }}",
          "dictItemId": "{{ vars.decree_entry.dictItemId }}",
          "ordinalNumber": "{{ vars.decree_entry.ordinalNumber }}"
        }
      }
    },
    {
      "id": "update_doc",
      "type": "http_request",
      "label": "Zastosuj dekretację do dokumentu",
      "position": {"x": 2600, "y": 300},
      "config": {
        "method": "PUT",
        "url": "http://connector-skanuj-fakture:8000/companies/{{ vars.sf_company_id }}/documents/{{ vars.target_doc_id }}?account_name={{ vars.sf_account }}",
        "body": {
          "data": {
            "decrets": "{{ vars.decree_entry_results }}"
          }
        },
        "timeout_seconds": 15
      }
    },
    {
      "id": "mark_attr",
      "type": "http_request",
      "label": "Oznacz dokument jako auto-dekretowany",
      "position": {"x": 2850, "y": 300},
      "config": {
        "method": "PUT",
        "url": "http://connector-skanuj-fakture:8000/companies/{{ vars.sf_company_id }}/documents/{{ vars.target_doc_id }}/attributes?account_name={{ vars.sf_account }}",
        "body": {
          "attributes": [
            {"name": "auto-dekret", "value": "true"}
          ]
        },
        "timeout_seconds": 10
      }
    },
    {
      "id": "resp_done",
      "type": "response",
      "label": "Dekretacja zastosowana",
      "position": {"x": 3100, "y": 300},
      "config": {
        "body": {
          "status": "decree_applied",
          "document_id": "{{ vars.target_doc_id }}"
        }
      }
    },
    {
      "id": "resp_skip_nip",
      "type": "response",
      "label": "Pominięto — brak NIP",
      "position": {"x": 250, "y": 100},
      "config": {
        "body": {"status": "skipped", "reason": "no_contractor_nip"}
      }
    },
    {
      "id": "resp_skip_decreed",
      "type": "response",
      "label": "Pominięto — już zadekretowany",
      "position": {"x": 500, "y": 100},
      "config": {
        "body": {"status": "skipped", "reason": "already_decreed"}
      }
    },
    {
      "id": "resp_skip_template",
      "type": "response",
      "label": "Pominięto — to dokument-wzór",
      "position": {"x": 750, "y": 100},
      "config": {
        "body": {"status": "skipped", "reason": "is_template_document"}
      }
    },
    {
      "id": "resp_no_template",
      "type": "response",
      "label": "Pominięto — brak szablonu",
      "position": {"x": 2100, "y": 100},
      "config": {
        "body": {"status": "skipped", "reason": "no_template_found"}
      }
    }
  ],
  "edges": [
    {"id": "e1",  "source": "trigger",             "target": "cond_has_nip",        "sourceHandle": "default"},
    {"id": "e2",  "source": "cond_has_nip",         "target": "cond_already_decreed","sourceHandle": "true"},
    {"id": "e3",  "source": "cond_has_nip",         "target": "resp_skip_nip",       "sourceHandle": "false"},
    {"id": "e4",  "source": "cond_already_decreed",  "target": "resp_skip_decreed",  "sourceHandle": "true"},
    {"id": "e5",  "source": "cond_already_decreed",  "target": "cond_is_template",   "sourceHandle": "false"},
    {"id": "e6",  "source": "cond_is_template",     "target": "resp_skip_template",  "sourceHandle": "true"},
    {"id": "e7",  "source": "cond_is_template",     "target": "save_doc_id",         "sourceHandle": "false"},
    {"id": "e8",  "source": "save_doc_id",           "target": "save_account",       "sourceHandle": "default"},
    {"id": "e9",  "source": "save_account",          "target": "save_company_id",    "sourceHandle": "default"},
    {"id": "e10", "source": "save_company_id",       "target": "get_docs",           "sourceHandle": "default"},
    {"id": "e11", "source": "get_docs",              "target": "loop_docs",          "sourceHandle": "default"},
    {"id": "e12", "source": "loop_docs",             "target": "cond_doc_attr",      "sourceHandle": "default", "label": "loop body"},
    {"id": "e13", "source": "loop_docs",             "target": "cond_template_found","sourceHandle": "done",    "label": "after loop"},
    {"id": "e14", "source": "cond_doc_attr",         "target": "cond_doc_decrets",   "sourceHandle": "true"},
    {"id": "e15", "source": "cond_doc_decrets",      "target": "save_template_dec",  "sourceHandle": "true"},
    {"id": "e16", "source": "cond_template_found",   "target": "loop_decrets",       "sourceHandle": "true"},
    {"id": "e17", "source": "cond_template_found",   "target": "resp_no_template",   "sourceHandle": "false"},
    {"id": "e18", "source": "loop_decrets",          "target": "resolve_amount",     "sourceHandle": "default", "label": "loop body"},
    {"id": "e19", "source": "resolve_amount",        "target": "rebuild_entry",      "sourceHandle": "default"},
    {"id": "e20", "source": "loop_decrets",          "target": "update_doc",         "sourceHandle": "done",    "label": "after loop"},
    {"id": "e21", "source": "update_doc",            "target": "mark_attr",          "sourceHandle": "default"},
    {"id": "e22", "source": "mark_attr",             "target": "resp_done",          "sourceHandle": "default"}
  ]
}
