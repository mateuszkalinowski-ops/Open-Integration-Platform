# S3 Integrator v1.0.0 — Environment Variables

# Application
S3_LOG_LEVEL=INFO
S3_DEBUG=false

# Database (poller state persistence)
DATABASE_URL=sqlite+aiosqlite:///./data/s3_integrator.db

# Kafka (set KAFKA_ENABLED=true to publish events to Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Polling for new objects
S3_POLLING_ENABLED=false
S3_POLLING_INTERVAL_SECONDS=300
S3_POLLING_BUCKET=
S3_POLLING_PREFIX=

# Connection timeouts
S3_CONNECT_TIMEOUT=15.0
S3_OPERATION_TIMEOUT=60.0

# Platform event notification
PLATFORM_API_URL=http://platform:8080
PLATFORM_API_KEY=
PLATFORM_EVENT_NOTIFY=true

# Accounts are configured in config/accounts.yaml
# Or via environment variables:
# S3_ACCOUNT_0_NAME=default
# S3_ACCOUNT_0_AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# S3_ACCOUNT_0_AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# S3_ACCOUNT_0_REGION=eu-central-1
# S3_ACCOUNT_0_ENDPOINT_URL=
# S3_ACCOUNT_0_DEFAULT_BUCKET=my-bucket
# S3_ACCOUNT_0_USE_PATH_STYLE=false
