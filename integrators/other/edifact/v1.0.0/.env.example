# EDIFACT Container Terminal Connector v1.0.0 — Environment Variables

# Application
EDIFACT_LOG_LEVEL=INFO
EDIFACT_DEBUG=false

# External terminal / TOS / PCS system
EDIFACT_BASE_URL=https://terminal-api.example.com
EDIFACT_API_KEY=your-api-key-here
EDIFACT_API_TIMEOUT_CONNECT=30
EDIFACT_API_TIMEOUT_READ=60
EDIFACT_MAX_RETRIES=3

# Kafka (set KAFKA_ENABLED=true to publish EDIFACT events)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Accounts are configured in config/accounts.yaml
# Or via environment variables:
# EDIFACT_BASE_URL=https://terminal-api.example.com
# EDIFACT_API_KEY=your-api-key

# Platform API (for event notifications)
PLATFORM_API_URL=http://platform:8080
PLATFORM_API_KEY=
PLATFORM_EVENT_NOTIFY=true
