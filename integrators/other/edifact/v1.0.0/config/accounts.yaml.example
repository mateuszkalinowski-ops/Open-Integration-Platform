# EDIFACT accounts configuration
# Copy to accounts.yaml and fill in credentials

accounts:
  - name: default
    base_url: "https://terminal-api.example.com"
    api_key: "your-api-key-here"
    description: "Main terminal system"

  # Multiple accounts example:
  # - name: terminal-b
  #   base_url: "https://terminal-b.example.com"
  #   api_key: "another-key"
  #   description: "Secondary terminal"
