# KSeF Integrator v1.0.0 — Environment Variables

# Application
KSEF_LOG_LEVEL=INFO
KSEF_DEBUG=false

# KSeF environment: test, demo, or production
# - test: https://api-test.ksef.mf.gov.pl (self-signed certs allowed)
# - demo: https://api-demo.ksef.mf.gov.pl (real credentials, no legal effect)
# - production: https://api.ksef.mf.gov.pl (real documents, legal effect)
KSEF_DEFAULT_ENVIRONMENT=demo

# Kafka (set KAFKA_ENABLED=true to publish invoice events)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Accounts are configured in config/accounts.yaml
# Or via environment variables:
# KSEF_ACCOUNT_0_NAME=default
# KSEF_ACCOUNT_0_NIP=1234567890
# KSEF_ACCOUNT_0_KSEF_TOKEN=your-ksef-token
# KSEF_ACCOUNT_0_ENVIRONMENT=demo

# Platform API (for event notifications)
PLATFORM_API_URL=http://platform:8080
PLATFORM_API_KEY=
PLATFORM_EVENT_NOTIFY=true
