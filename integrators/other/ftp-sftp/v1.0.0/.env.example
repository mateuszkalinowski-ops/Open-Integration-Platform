# FTP/SFTP Integrator v1.0.0 — Environment Variables

# Application
FTP_LOG_LEVEL=INFO
FTP_DEBUG=false

# Database (poller state persistence)
DATABASE_URL=sqlite+aiosqlite:///./data/ftp_sftp_integrator.db

# Kafka (set KAFKA_ENABLED=true to publish events to Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Polling for new files
FTP_POLLING_ENABLED=false
FTP_POLLING_INTERVAL_SECONDS=300
FTP_POLLING_PATH=/

# Connection timeouts
FTP_CONNECT_TIMEOUT=15.0
FTP_OPERATION_TIMEOUT=60.0

# Platform event notification
PLATFORM_API_URL=http://platform:8080
PLATFORM_API_KEY=
PLATFORM_EVENT_NOTIFY=true

# Accounts are configured in config/accounts.yaml
# Or via environment variables:
# FTP_ACCOUNT_0_NAME=default
# FTP_ACCOUNT_0_HOST=ftp.example.com
# FTP_ACCOUNT_0_PROTOCOL=sftp
# FTP_ACCOUNT_0_PORT=22
# FTP_ACCOUNT_0_USERNAME=user
# FTP_ACCOUNT_0_PASSWORD=pass
# FTP_ACCOUNT_0_PRIVATE_KEY=
# FTP_ACCOUNT_0_PASSIVE_MODE=true
# FTP_ACCOUNT_0_BASE_PATH=/
