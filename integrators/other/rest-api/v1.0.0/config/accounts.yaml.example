accounts:
  - name: clip-malaszewicze
    description: "Pinquark TOS — terminal Clip Malaszewicze"
    profile: pinquark
    base_url: https://clip-malaszewicze.pinquark.app
    path_prefix: /integration
    default_method: POST
    auth:
      type: bearer_with_custom_headers
      bearer_token: "${CLIP_BEARER_TOKEN}"
      custom_headers:
        token-mer: "${CLIP_MER_TOKEN}"
    timeouts:
      connect_s: 30
      read_s: 60
    retry:
      max_attempts: 3
      backoff_initial_s: 2
      backoff_multiplier: 2
      retryable_status_codes: [429, 502, 503, 504]
    rate_limit: "600/min"
    action_registry:
      awk.create:
        endpoint: tos_notification_rail_save
        description: "Tworzy awizacje kolejowa (AWK)"
      awk.approve:
        endpoint: tos_notification_rail_approve
        description: "Zatwierdza AWK -> tworzy KZT"
      events.poll:
        endpoint: tos_get_events_since
        description: "Polling tos_audit_log od kursora"
      doc_status_changes.poll:
        endpoint: tos_get_doc_status_changes_since
        description: "Polling zmian statusow dokumentow"
