# REST API Gateway Connector
REST_API_HOST=0.0.0.0
REST_API_PORT=8000
REST_API_LOG_LEVEL=INFO
REST_API_DEBUG=false

# Default timeouts (seconds)
REST_API_DEFAULT_CONNECT_TIMEOUT=30
REST_API_DEFAULT_READ_TIMEOUT=60
REST_API_DEFAULT_MAX_RETRIES=3

# Accounts config path
REST_API_ACCOUNTS_CONFIG_PATH=/app/config/accounts.yaml
REST_API_PROFILES_DIR=/app/config/profiles

# Platform integration
PLATFORM_API_URL=http://platform:8080
PLATFORM_API_KEY=
PLATFORM_INTERNAL_SECRET=
