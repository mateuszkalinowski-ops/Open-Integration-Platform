# Slack Integrator v1.0.0 — Environment Variables

# Application
SLACK_LOG_LEVEL=INFO
SLACK_DEBUG=false

# Database (poller state persistence)
DATABASE_URL=sqlite+aiosqlite:///./data/slack_integrator.db
DATABASE_ENCRYPTION_KEY=  # base64-encoded 32-byte AES key; generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"

# Kafka (set KAFKA_ENABLED=true to publish events to Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Polling
SLACK_POLLING_ENABLED=true
SLACK_POLLING_INTERVAL_SECONDS=30

# Accounts are configured in config/accounts.yaml
# Or via environment variables:
# SLACK_ACCOUNT_0_NAME=default
# SLACK_ACCOUNT_0_BOT_TOKEN=xoxb-your-bot-token
# SLACK_ACCOUNT_0_APP_TOKEN=xapp-your-app-token
# SLACK_ACCOUNT_0_DEFAULT_CHANNEL=general
