# Email Client Integrator v1.0.0 — Environment Variables

# Application
EMAIL_LOG_LEVEL=INFO
EMAIL_DEBUG=false

# Database (poller state persistence)
DATABASE_URL=sqlite+aiosqlite:///./data/email_client_integrator.db
DATABASE_ENCRYPTION_KEY=  # base64-encoded 32-byte AES key; generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"

# Kafka (set KAFKA_ENABLED=true to publish email events to Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Polling
EMAIL_POLLING_ENABLED=true
EMAIL_POLLING_INTERVAL_SECONDS=60
EMAIL_POLLING_FOLDER=INBOX
EMAIL_POLLING_MAX_EMAILS=50

# Accounts are configured in config/accounts.yaml
# Or via environment variables:
# EMAIL_ACCOUNT_0_NAME=default
# EMAIL_ACCOUNT_0_EMAIL_ADDRESS=user@example.com
# EMAIL_ACCOUNT_0_USERNAME=              # optional — if IMAP/SMTP login differs from email
# EMAIL_ACCOUNT_0_PASSWORD=app-password-here
# EMAIL_ACCOUNT_0_IMAP_HOST=imap.gmail.com
# EMAIL_ACCOUNT_0_IMAP_PORT=993
# EMAIL_ACCOUNT_0_SMTP_HOST=smtp.gmail.com
# EMAIL_ACCOUNT_0_SMTP_PORT=587
# EMAIL_ACCOUNT_0_USE_SSL=true
# EMAIL_ACCOUNT_0_POLLING_FOLDER=INBOX
