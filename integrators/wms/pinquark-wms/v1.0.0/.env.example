# Pinquark WMS Integration REST API connector
# Base URL of the Pinquark WMS integration-rest application
PINQUARK_WMS_API_URL=http://localhost:8090

# Credentials (use secrets manager in production)
PINQUARK_WMS_USERNAME=
PINQUARK_WMS_PASSWORD=

# HTTP timeouts (seconds)
PINQUARK_WMS_HTTP_CONNECT_TIMEOUT=30
PINQUARK_WMS_HTTP_READ_TIMEOUT=60

# Logging
PINQUARK_WMS_LOG_LEVEL=INFO
