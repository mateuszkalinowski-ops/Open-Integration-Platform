# IdoSell Integrator v1.0.0 — Environment Variables

# Application
IDOSELL_LOG_LEVEL=INFO
IDOSELL_DEBUG=false

# Database (scraper state persistence)
DATABASE_URL=sqlite+aiosqlite:///./data/idosell_integrator.db
DATABASE_ENCRYPTION_KEY=  # base64-encoded 32-byte AES key; generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"

# Kafka (set KAFKA_ENABLED=true to publish orders to Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Scraping
IDOSELL_SCRAPING_ENABLED=true
IDOSELL_SCRAPING_INTERVAL_SECONDS=120

# Accounts are configured in config/accounts.yaml
# Or via environment variables:
#
# Modern auth (X-API-KEY header, /api/admin/{version}/ URLs):
# IDOSELL_ACCOUNT_0_NAME=default
# IDOSELL_ACCOUNT_0_SHOP_URL=https://client12345.idosell.com
# IDOSELL_ACCOUNT_0_API_KEY=your_api_key_here
# IDOSELL_ACCOUNT_0_AUTH_MODE=api_key
# IDOSELL_ACCOUNT_0_API_VERSION=v6
#
# Legacy auth (SHA-1 daily key in body, /admin/{version}/ URLs — Java compat):
# IDOSELL_ACCOUNT_0_NAME=legacy-account
# IDOSELL_ACCOUNT_0_SHOP_URL=https://client12345.idosell.com
# IDOSELL_ACCOUNT_0_LOGIN=your_login
# IDOSELL_ACCOUNT_0_PASSWORD=your_password
# IDOSELL_ACCOUNT_0_AUTH_MODE=legacy
# IDOSELL_ACCOUNT_0_API_VERSION=v7
