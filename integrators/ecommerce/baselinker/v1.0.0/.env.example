# BaseLinker Integrator v1.0.0 — Environment Variables

# Application
BASELINKER_LOG_LEVEL=INFO
BASELINKER_DEBUG=false

# Database (scraper state persistence)
DATABASE_URL=sqlite+aiosqlite:///./data/baselinker_integrator.db
DATABASE_ENCRYPTION_KEY=  # base64-encoded 32-byte AES key

# Kafka (set KAFKA_ENABLED=true to publish orders to Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Scraping
BASELINKER_SCRAPING_ENABLED=true
BASELINKER_SCRAPING_INTERVAL_SECONDS=120

# Accounts configured in config/accounts.yaml or via env vars:
# BASELINKER_ACCOUNT_0_NAME=default
# BASELINKER_ACCOUNT_0_API_TOKEN=your-bl-token-here
# BASELINKER_ACCOUNT_0_INVENTORY_ID=0
# BASELINKER_ACCOUNT_0_WAREHOUSE_ID=0
