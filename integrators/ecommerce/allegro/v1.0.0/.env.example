# Allegro Integrator v1.0.0 — Environment Variables

# Application
ALLEGRO_LOG_LEVEL=INFO
ALLEGRO_DEBUG=false

# Database (token persistence)
DATABASE_URL=sqlite+aiosqlite:///./data/allegro_integrator.db
DATABASE_ENCRYPTION_KEY=  # base64-encoded 32-byte AES key, generate with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"

# Kafka (set KAFKA_ENABLED=true to publish orders to Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Scraping
ALLEGRO_SCRAPING_ENABLED=true
ALLEGRO_SCRAPING_INTERVAL_SECONDS=60

# Accounts are configured in config/accounts.yaml
# Or via environment variables:
# ALLEGRO_ACCOUNT_0_NAME=default
# ALLEGRO_ACCOUNT_0_CLIENT_ID=your-client-id
# ALLEGRO_ACCOUNT_0_CLIENT_SECRET=your-client-secret
# ALLEGRO_ACCOUNT_0_API_URL=https://api.allegro.pl.allegrosandbox.pl
# ALLEGRO_ACCOUNT_0_AUTH_URL=https://allegro.pl.allegrosandbox.pl/auth/oauth
# ALLEGRO_ACCOUNT_0_ENVIRONMENT=sandbox
