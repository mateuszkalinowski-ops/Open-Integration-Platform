# WooCommerce Integrator v1.0.0 — Environment Variables

# Application
WOOCOMMERCE_LOG_LEVEL=INFO
WOOCOMMERCE_DEBUG=false

# Database (token/state persistence)
DATABASE_URL=sqlite+aiosqlite:///./data/woocommerce_integrator.db
DATABASE_ENCRYPTION_KEY=  # base64-encoded 32-byte AES key, generate with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"

# Kafka (set KAFKA_ENABLED=true to publish orders to Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Scraping
WOOCOMMERCE_SCRAPING_ENABLED=true
WOOCOMMERCE_SCRAPING_INTERVAL_SECONDS=60

# Accounts are configured in config/accounts.yaml
# Or via environment variables:
# WOOCOMMERCE_ACCOUNT_0_NAME=default
# WOOCOMMERCE_ACCOUNT_0_STORE_URL=https://your-store.com
# WOOCOMMERCE_ACCOUNT_0_CONSUMER_KEY=ck_xxxxx
# WOOCOMMERCE_ACCOUNT_0_CONSUMER_SECRET=cs_xxxxx
# WOOCOMMERCE_ACCOUNT_0_API_VERSION=wc/v3
# WOOCOMMERCE_ACCOUNT_0_VERIFY_SSL=true
