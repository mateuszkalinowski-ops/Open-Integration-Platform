# Shopify Integrator v1.0.0 — Environment Variables

# Application
SHOPIFY_LOG_LEVEL=INFO
SHOPIFY_DEBUG=false

# Database (token & state persistence)
DATABASE_URL=sqlite+aiosqlite:///./data/shopify_integrator.db
DATABASE_ENCRYPTION_KEY=  # base64-encoded 32-byte AES key, generate with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"

# Kafka (set KAFKA_ENABLED=true to publish orders to Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Scraping
SHOPIFY_SCRAPING_ENABLED=true
SHOPIFY_SCRAPING_INTERVAL_SECONDS=60

# Accounts are configured in config/accounts.yaml
# Or via environment variables:
# SHOPIFY_ACCOUNT_0_NAME=default
# SHOPIFY_ACCOUNT_0_SHOP_URL=my-store.myshopify.com
# SHOPIFY_ACCOUNT_0_ACCESS_TOKEN=shpat_xxxxx
# SHOPIFY_ACCOUNT_0_API_VERSION=2024-07
# SHOPIFY_ACCOUNT_0_DEFAULT_LOCATION_ID=
