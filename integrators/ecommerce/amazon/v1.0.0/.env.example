# Amazon Integrator v1.0.0 — Environment Variables

# Application
AMAZON_LOG_LEVEL=INFO
AMAZON_DEBUG=false

# Database (scraper state persistence)
DATABASE_URL=sqlite+aiosqlite:///./data/amazon_integrator.db
DATABASE_ENCRYPTION_KEY=  # base64-encoded 32-byte AES key

# Kafka (set KAFKA_ENABLED=true to publish orders to Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Scraping
AMAZON_SCRAPING_ENABLED=true
AMAZON_SCRAPING_INTERVAL_SECONDS=300

# Accounts configured in config/accounts.yaml or via env vars:
# AMAZON_ACCOUNT_0_NAME=default
# AMAZON_ACCOUNT_0_CLIENT_ID=amzn1.application-oa2-client.xxxx
# AMAZON_ACCOUNT_0_CLIENT_SECRET=your-client-secret
# AMAZON_ACCOUNT_0_REFRESH_TOKEN=Atzr|XXXX
# AMAZON_ACCOUNT_0_MARKETPLACE_ID=A1PA6795UKMFR9
# AMAZON_ACCOUNT_0_REGION=eu
