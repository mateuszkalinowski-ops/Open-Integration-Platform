# Apilo Integrator v1.0.0 — Environment Variables

# Application
APILO_LOG_LEVEL=INFO
APILO_DEBUG=false

# Database (scraper state persistence)
DATABASE_URL=sqlite+aiosqlite:///./data/apilo_integrator.db
DATABASE_ENCRYPTION_KEY=  # base64-encoded 32-byte AES key

# Kafka (set KAFKA_ENABLED=true to publish orders to Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Scraping
APILO_SCRAPING_ENABLED=true
APILO_SCRAPING_INTERVAL_SECONDS=300

# Rate limit (Apilo API limit: 150 req/min)
APILO_RATE_LIMIT_RPM=150

# Accounts configured in config/accounts.yaml or via env vars:
# APILO_ACCOUNT_0_NAME=default
# APILO_ACCOUNT_0_CLIENT_ID=your-client-id
# APILO_ACCOUNT_0_CLIENT_SECRET=your-client-secret
# APILO_ACCOUNT_0_AUTHORIZATION_CODE=your-authorization-code
# APILO_ACCOUNT_0_REFRESH_TOKEN=your-refresh-token
# APILO_ACCOUNT_0_BASE_URL=https://app.apilo.com
