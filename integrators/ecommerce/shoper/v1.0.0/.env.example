# Shoper Integrator v1.0.0 — Environment Variables

# Application
SHOPER_LOG_LEVEL=INFO
SHOPER_DEBUG=false

# Database (token & scraper state persistence)
DATABASE_URL=sqlite+aiosqlite:///./data/shoper_integrator.db
DATABASE_ENCRYPTION_KEY=  # base64-encoded 32-byte AES key; generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"

# Kafka (set KAFKA_ENABLED=true to publish orders to Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Scraping
SHOPER_SCRAPING_ENABLED=true
SHOPER_SCRAPING_INTERVAL_SECONDS=300

# Accounts are configured in config/accounts.yaml
# Or via environment variables:
# SHOPER_ACCOUNT_0_NAME=default
# SHOPER_ACCOUNT_0_SHOP_URL=https://myshop.shoparena.pl
# SHOPER_ACCOUNT_0_LOGIN=admin
# SHOPER_ACCOUNT_0_PASSWORD=secret
# SHOPER_ACCOUNT_0_LANGUAGE_ID=pl_PL
