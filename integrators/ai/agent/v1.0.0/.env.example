# AI Agent — environment variables
# Copy to .env and fill in your values

# Required: Google Gemini API key (get free at https://aistudio.google.com/apikey)
AI_GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Model selection
# Options: gemini-2.5-flash (default, free), gemini-2.5-flash-lite, gemini-2.5-pro
AI_MODEL_NAME=gemini-2.5-flash

# Optional: Model parameters
AI_DEFAULT_TEMPERATURE=0.1
AI_MAX_TOKENS=2048

# Optional: Risk thresholds (for built-in risk analysis template)
AI_RISK_THRESHOLD_HIGH=60
AI_RISK_THRESHOLD_CRITICAL=85

# Optional: Available couriers (for built-in courier recommendation template)
AI_AVAILABLE_COURIERS=inpost,dhl,dpd,gls,fedex,ups,pocztapolska,orlenpaczka

# Logging
AI_LOG_LEVEL=INFO
